# Google AI (Gemini) — clé API : https://aistudio.google.com/apikey
# Laisser vide pour forcer le fallback fixture (déterministe) côté runner.
GEMINI_API_KEY=

# Modèle Gemini utilisé par le Planner/Worker (Lot 2+).
# GEMINI_MODEL=gemini-2.5-flash

# Plafond d'appels d'outils (function calling) pour le Worker (Lot 2+).
# MAX_TOOL_CALLS=10

# Budget wallclock (secondes) pour l'orchestration Planner+Worker (Lot 2+).
# AGENT_WALL_CLOCK_S=60

# Origines autorisées pour CORS (séparées par des virgules). Inclure l’URL Vercel en prod.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Région logique du runner (affichée dans /health et les traces).
REGION=local

# Version exposée dans /health.
RUNNER_VERSION=0.1.0
