# ──────────────────────────────────────────────────────────────
#  ArcadeOps Control Tower — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy to `.env.local` (NEVER commit `.env.local`).
# All variables below are OPTIONAL. The replay demo works without any of them.

# ── Live ArcadeOps backend (optional) ─────────────────────────
# When all three are set, the UI enables the "Run live with ArcadeOps backend"
# button. The browser never sees the token: requests flow through the
# server-side proxy at `/api/arcadeops/run`.
ARCADEOPS_API_BASE_URL=
ARCADEOPS_DEMO_TOKEN=
ARCADEOPS_DEMO_AGENT_ID=

# ── Live Gemini analysis (optional, future) ───────────────────
# Reserved for the upcoming Gemini live mode. Not used in V0/V1.
GEMINI_API_KEY=
