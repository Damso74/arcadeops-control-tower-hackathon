# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env
.env.local
.env.*
.env*
# Allow the documented template (no secrets — only variable names + comments).
!.env.example

# vercel
.vercel

# Cursor agent local state — not part of the demo
.cursor/

# typescript
*.tsbuildinfo
next-env.d.ts

# Vultr provisioning state (Lot 1b)
.vultr-state.json
.vultr-*.log

# Runner local debug/smoke artifacts (Lot 2)
runner/.uvicorn.log
runner/.uvicorn.err.log
runner/.smoke-payload.json
runner/.smoke-response.json

# Local Python virtualenv + bytecode (never ship to repo) — Lot 5 FULL
runner/.venv/
runner/**/__pycache__/
runner/**/*.pyc

# Smoke fixtures generated during prod proxying (Lot 4 / Lot 5)
.smoke-*.json
.smoke-*.log

# Local-only Lot 5 FULL secrets — never commit, regenerate per-deploy.
.runner-secret.local
.runner-url.local
