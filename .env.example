# ──────────────────────────────────────────────────────────────
#  ArcadeOps Control Tower — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy to `.env.local` (NEVER commit `.env.local`).
# All variables below are OPTIONAL. The replay demo works without any of them.

# ── Google Gemini Reliability Judge (recommended) ─────────────
# When GEMINI_API_KEY is set, the /control-tower page enables the
# "Run Gemini reliability judge" button. Gemini reads the replayed agent
# trace and returns a production-readiness verdict, risks, missing
# evidence and a remediation plan.
#
# Get a key: https://aistudio.google.com/app/apikey
# The key is read by /api/gemini/judge on the server only — it never
# reaches the browser.
GEMINI_API_KEY=

# Optional override. Defaults to "gemini-2.5-flash" — fast, cheap, and
# returns valid JSON consistently for short audit prompts. Bigger models
# such as "gemini-2.5-pro" produce richer verdicts but cost more per call.
GEMINI_MODEL=

# ── Live ArcadeOps backend (optional) ─────────────────────────
# When all three are set, the UI enables the "Run live with ArcadeOps backend"
# button. The browser never sees the token: requests flow through the
# server-side proxy at `/api/arcadeops/run`. Leave empty to keep the public
# deployment in safe replay-only mode.
ARCADEOPS_API_BASE_URL=
ARCADEOPS_DEMO_TOKEN=
ARCADEOPS_DEMO_AGENT_ID=
